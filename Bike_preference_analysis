--Analyzing the bike type preferences of casual and member riders

SELECT 
    member_casual,
    rideable_type,
    COUNT(*) as total_rides,
    AVG(TIME_DIFF(ride_length, TIME '00:00:00', MINUTE)) as avg_ride_length
FROM `portfolio-488812.bikeshare.cleaned_all`
GROUP BY member_casual, rideable_type
ORDER BY member_casual
