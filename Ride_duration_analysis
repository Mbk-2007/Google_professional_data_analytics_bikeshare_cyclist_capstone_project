-- Analysis of ride duration per month by casual and member riders

SELECT 
    member_casual,
    COUNT(*) as total_rides,
    CASE month
    WHEN 7 then 'July'
    WHEN 8 then 'August'
    WHEN 9 then 'September'
    WHEN 10 then 'October'
    WHEN 11 then 'November'
    WHEN 12 then 'December'
    END as month,
    -- Convert TIME to minutes (hours*60 + minutes + seconds/60)
    AVG(TIME_DIFF(ride_length, TIME '00:00:00', MINUTE)) as avg_ride_length_minutes,
    MAX(TIME_DIFF(ride_length, TIME '00:00:00', MINUTE)) as max_ride_length,
    MIN(TIME_DIFF(ride_length, TIME '00:00:00', MINUTE)) as min_ride_length,
FROM `portfolio-488812.bikeshare.cleaned_all`
WHERE month <> 6
GROUP BY member_casual, month
ORDER BY month;
